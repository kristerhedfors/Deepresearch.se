#!/usr/bin/env bash
# Pre-push git hook (security register P-2): block a push that would carry a
# credential-shaped token into the PUBLIC, auto-deploying repo. Runs
# scripts/scan-secrets over exactly the commits being pushed.
#
# Activated by scripts/install-git-hooks (sets core.hooksPath=.githooks); a
# fresh clone does NOT run it until that script has been run once.
#
# Git invokes this hook with "<remote-name> <remote-url>" as $1/$2 and feeds
# one line per ref being pushed on stdin:
#     <local ref> <local sha> <remote ref> <remote sha>
# For each updated ref we scan <remote sha>..<local sha> (the outgoing commits).
# A new branch on the remote reports an all-zero remote sha; there we fall back
# to scanning the local commits not yet on any remote tracking ref.
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
scan="$repo_root/scripts/scan-secrets"
zero='0000000000000000000000000000000000000000'
rc=0

# Pipeline-sensitive files (the P7 bench-gate discipline, docs/TESTING.md):
# an outgoing change to any of these gets a REMINDER (never a block — the
# gate needs live creds and a deployment, so it can't run here) that the
# scored bench gate applies to it.
bench_sensitive='^src/(pipeline|pipeline-inputs|prompts|budget|model-profiles|schema|triage|answer-stream|notes|sources|search-sources|exa|berget)\.js$'
bench_hit=""

while read -r local_ref local_sha remote_ref remote_sha; do
  # Branch deletion: nothing being added, skip.
  [ "$local_sha" = "$zero" ] && continue

  if [ "$remote_sha" = "$zero" ]; then
    # New remote ref: scan commits not already reachable from other refs.
    range="$(git rev-list "$local_sha" --not --remotes | tail -n1)"
    if [ -n "$range" ]; then
      range="${range}~1..${local_sha}"
    else
      range="$local_sha"   # single new commit / unrooted
    fi
  else
    range="${remote_sha}..${local_sha}"
  fi

  if ! "$scan" --range "$range"; then
    rc=1
  fi

  hit="$(git diff --name-only "$range" 2>/dev/null | grep -E "$bench_sensitive" | head -5 || true)"
  [ -n "$hit" ] && bench_hit="$hit"
done

if [ -n "$bench_hit" ]; then
  echo "pre-push: NOTE — outgoing commits touch pipeline-sensitive files:" >&2
  echo "$bench_hit" | sed 's/^/pre-push:   /' >&2
  echo "pre-push: the scored bench gate applies (docs/TESTING.md): run 'npm run bench:gate'" >&2
  echo "pre-push: in tests/ against the deployment before+after, and append the" >&2
  echo "pre-push: printed ledger line to tests/EVAL-BENCH-FINDINGS.md." >&2
fi

if [ "$rc" -ne 0 ]; then
  echo "pre-push: BLOCKED — a credential-shaped token is in the outgoing commits." >&2
  echo "pre-push: fix the finding above, or (verified false positive) push with --no-verify." >&2
  exit 1
fi
exit 0
