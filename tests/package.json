{
  "name": "deepresearch-e2e",
  "private": true,
  "type": "module",
  "description": "End-to-end tests against the live site using break-glass Basic Auth. Run: BASIC_AUTH_USER=\u2026 BASIC_AUTH_PASS=\u2026 npm test",
  "scripts": {
    "fixtures": "python3 make_fixtures.py",
    "test": "playwright test",
    "test:live": "playwright test --grep @live",
    "test:mocked": "playwright test --grep-invert @live",
    "eval:models": "node model-eval.mjs",
    "eval:bench": "node eval-bench.mjs",
    "eval:hf": "node hf-bench.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0"
  }
}
