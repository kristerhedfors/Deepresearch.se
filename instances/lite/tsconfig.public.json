{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true
  },
  "include": ["public/js/**/*.js"],
  "exclude": ["public/js/**/*.test.js"]
}
