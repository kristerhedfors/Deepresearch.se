#!/usr/bin/env bash
# Latest chat interactions from the LIVE site — the agentic-debugging window
# into what users (and agents) just asked and what the pipeline answered.
# Wraps GET /api/admin/chatlogs (src/chatlog.js) using the break-glass Basic
# Auth credentials, the same BASIC_AUTH_USER / BASIC_AUTH_PASS env vars the
# e2e suite uses. See .claude/skills/chat-logs/SKILL.md.
#
# Usage:
#   scripts/chatlogs                   last 10 interactions, readable text
#   scripts/chatlogs 25                last 25
#   scripts/chatlogs --errors          only failed/disconnected interactions
#   scripts/chatlogs --id 42           one interaction, full conversation+meta (JSON)
#   scripts/chatlogs --q "some term"   substring match on question OR answer
#   scripts/chatlogs --json            JSON instead of text (any of the above)
#   scripts/chatlogs --params "user=3&channel=mcp&since=1751970000000"
#
# BASE_URL overrides the target (default https://deepresearch.se).
set -euo pipefail

: "${BASIC_AUTH_USER:?Set BASIC_AUTH_USER (break-glass credentials)}"
: "${BASIC_AUTH_PASS:?Set BASIC_AUTH_PASS (break-glass credentials)}"
BASE_URL="${BASE_URL:-https://deepresearch.se}"

limit=10
format="text"
id=""
query=""
extra=""
errors=""

while [ $# -gt 0 ]; do
  case "$1" in
    --json) format="json" ;;
    --errors) errors="1" ;;
    --id) id="$2"; shift ;;
    --q) query="$2"; shift ;;
    --params) extra="$2"; shift ;;
    [0-9]*) limit="$1" ;;
    *) echo "unknown argument: $1" >&2; exit 2 ;;
  esac
  shift
done

curl_auth() {
  curl -sS -u "$BASIC_AUTH_USER:$BASIC_AUTH_PASS" "$@"
}

if [ -n "$id" ]; then
  url="$BASE_URL/api/admin/chatlogs/$id"
  [ "$format" = "text" ] && url="$url?format=text"
  curl_auth "$url"
  exit 0
fi

qs="limit=$limit"
[ "$format" = "text" ] && qs="$qs&format=text"
[ -n "$errors" ] && qs="$qs&errors=1"
[ -n "$query" ] && qs="$qs&q=$(printf %s "$query" | jq -sRr @uri)"
[ -n "$extra" ] && qs="$qs&$extra"

curl_auth "$BASE_URL/api/admin/chatlogs?$qs"
