#!/usr/bin/env bash
# The user-feedback queue on the LIVE site — the agent side of Feedback mode.
# Wraps /api/admin/feedback (src/feedback.js) using the break-glass Basic
# Auth credentials, the same BASIC_AUTH_USER / BASIC_AUTH_PASS env vars the
# e2e suite and scripts/chatlogs use. See .claude/skills/feedback-loop/SKILL.md
# for the loop this is the CRUD layer of.
#
# Usage:
#   scripts/feedback                       open entries (the work queue), readable text
#   scripts/feedback --all                 all entries, any status
#   scripts/feedback 25                    limit (default 20)
#   scripts/feedback --id 7                one entry with its full thread
#   scripts/feedback --status 7 in_progress    set status (new|seen|in_progress|resolved|declined)
#   scripts/feedback --reply 7 "text"      post the agent's reply onto the thread
#   scripts/feedback --image 7 12 [out]    download screenshot #12 from entry #7
#                                          (ids from the IMAGES: lines; default
#                                          out feedback-7-image-12.jpg)
#   scripts/feedback --delete 7            delete an entry + its thread
#   scripts/feedback --q "some term"       substring match on comment OR question
#   scripts/feedback --json                JSON instead of text (list/--id)
#   scripts/feedback --params "user=3&since=1751970000000"
#
# BASE_URL overrides the target (default https://deepresearch.se).
set -euo pipefail

: "${BASIC_AUTH_USER:?Set BASIC_AUTH_USER (break-glass credentials)}"
: "${BASIC_AUTH_PASS:?Set BASIC_AUTH_PASS (break-glass credentials)}"
BASE_URL="${BASE_URL:-https://deepresearch.se}"

limit=20
format="text"
id=""
query=""
extra=""
open="1"
action=""
arg=""
out=""

while [ $# -gt 0 ]; do
  case "$1" in
    --json) format="json" ;;
    --all) open="" ;;
    --id) id="$2"; shift ;;
    --q) query="$2"; shift ;;
    --params) extra="$2"; shift ;;
    --status) action="status"; id="$2"; arg="$3"; shift 2 ;;
    --reply) action="reply"; id="$2"; arg="$3"; shift 2 ;;
    --image)
      action="image"; id="$2"; arg="$3"
      if [ $# -ge 4 ]; then out="$4"; shift 3; else shift 2; fi ;;
    --delete) action="delete"; id="$2"; shift ;;
    [0-9]*) limit="$1" ;;
    *) echo "unknown argument: $1" >&2; exit 2 ;;
  esac
  shift
done

curl_auth() {
  curl -sS -u "$BASIC_AUTH_USER:$BASIC_AUTH_PASS" "$@"
}

case "$action" in
  status)
    curl_auth -X PATCH -H 'content-type: application/json' \
      -d "$(jq -n --arg s "$arg" '{status:$s}')" \
      "$BASE_URL/api/admin/feedback/$id"
    exit 0 ;;
  reply)
    curl_auth -X POST -H 'content-type: application/json' \
      -d "$(jq -n --arg b "$arg" '{body:$b}')" \
      "$BASE_URL/api/admin/feedback/$id/messages"
    exit 0 ;;
  image)
    out="${out:-feedback-${id}-image-${arg}.jpg}"
    curl_auth -o "$out" "$BASE_URL/api/admin/feedback/$id/images/$arg"
    echo "saved $out"
    exit 0 ;;
  delete)
    curl_auth -X DELETE "$BASE_URL/api/admin/feedback/$id"
    exit 0 ;;
esac

if [ -n "$id" ]; then
  url="$BASE_URL/api/admin/feedback/$id"
  [ "$format" = "text" ] && url="$url?format=text"
  curl_auth "$url"
  exit 0
fi

qs="limit=$limit"
[ "$format" = "text" ] && qs="$qs&format=text"
[ -n "$open" ] && qs="$qs&open=1"
[ -n "$query" ] && qs="$qs&q=$(printf %s "$query" | jq -sRr @uri)"
[ -n "$extra" ] && qs="$qs&$extra"

curl_auth "$BASE_URL/api/admin/feedback?$qs"
