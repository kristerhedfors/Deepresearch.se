#!/usr/bin/env bash
# Mechanical secret-leak scan for THIS repo (security register P-2). The repo is
# PUBLIC and auto-deploys from main, so a committed credential is published and
# deployed instantly — this is the last mechanical gate before that happens.
# The credential pattern set is the canonical one from the security-posture
# skill (.claude/skills/security-posture/SKILL.md §1): OpenAI sk-, Berget
# sk_ber_, Groq gsk_, Anthropic sk-ant-, AWS AKIA, GitHub ghp_/github_pat_,
# Google AIza, Slack xox*, and PEM private-key blocks. Keep the two in sync.
#
# Matches are REDACTED in the output (provider prefix + length only) so running
# the scanner never itself prints a full secret into a log or terminal buffer.
#
# Usage:
#   scripts/scan-secrets                 scan the working tree's tracked+staged files
#   scripts/scan-secrets --staged        scan the staged diff (pre-commit/pre-push)
#   scripts/scan-secrets --range A..B     scan the added lines of a commit range
#
# Exit status: 0 = PASS (nothing matched), 1 = FAIL (a token matched),
#              2 = bad arguments. Used non-interactively by .githooks/pre-push.
set -euo pipefail

# Canonical credential patterns (security-posture skill §1). Constructed so the
# pattern text itself does NOT self-match: every literal prefix is immediately
# followed by a bracketed character class, so this file scans clean.
PATTERN='(sk-[A-Za-z0-9_-]{24,}|sk_ber_[A-Za-z0-9_-]{8,}|gsk_[A-Za-z0-9]{16,}|AKIA[0-9A-Z]{16}|ghp_[A-Za-z0-9]{20,}|github_pat_[A-Za-z0-9_]{20,}|AIza[0-9A-Za-z_-]{35}|xox[bpoas]-[A-Za-z0-9-]{10,}|-----BEGIN [A-Z ]*PRIVATE KEY-----)'

mode="worktree"
range=""

while [ $# -gt 0 ]; do
  case "$1" in
    --staged) mode="staged" ;;
    --range) mode="range"; range="${2:-}"; shift ;;
    -h|--help) sed -n '2,20p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    *) echo "unknown argument: $1" >&2; exit 2 ;;
  esac
  shift
done

if [ "$mode" = "range" ] && [ -z "$range" ]; then
  echo "--range needs a commit range, e.g. --range origin/main..HEAD" >&2
  exit 2
fi

cd "$(git rev-parse --show-toplevel)"

# redact <token> -> "<4-char prefix>…[REDACTED N chars]" (the prefix is the
# non-secret provider marker; the secret body is never printed).
redact() {
  local tok="$1"
  printf '%s…[REDACTED %d chars]' "${tok:0:4}" "${#tok}"
}

# emit prints one "location<TAB>token" line per match for the selected mode.
emit() {
  case "$mode" in
    worktree)
      # On-disk content of every tracked-or-staged file (git ls-files reads the
      # index, so staged-new files are included alongside working-tree edits).
      git ls-files -z | while IFS= read -r -d '' f; do
        [ -f "$f" ] || continue
        grep -aonE "$PATTERN" -- "$f" 2>/dev/null | while IFS= read -r hit; do
          printf '%s\t%s\n' "$f:${hit%%:*}" "${hit#*:}"
        done || true
      done
      ;;
    staged|range)
      # Only ADDED lines (the diff about to enter history), attributed to the
      # file from the most recent +++ header. -U0 keeps context out of scope.
      local diffcmd
      if [ "$mode" = "staged" ]; then diffcmd=(git diff --cached -U0); else diffcmd=(git diff -U0 "$range"); fi
      "${diffcmd[@]}" | awk '
        /^\+\+\+ /{ f=$2; sub(/^b\//,"",f); next }
        /^\+/ && !/^\+\+\+/ { print f "\t" substr($0,2) }
      ' | while IFS=$'\t' read -r f content; do
        printf '%s\n' "$content" | grep -aoE "$PATTERN" 2>/dev/null | while IFS= read -r tok; do
          printf '%s\t%s\n' "$f" "$tok"
        done || true
      done
      ;;
  esac
}

found=0
while IFS=$'\t' read -r loc tok; do
  [ -z "$loc" ] && continue
  found=$((found + 1))
  printf '  %-48s  %s\n' "$loc" "$(redact "$tok")"
done < <(emit)

echo
if [ "$found" -gt 0 ]; then
  echo "FAIL: $found credential-shaped token(s) matched ($mode scan)."
  echo
  echo "ROTATION RUNBOOK — a real secret here is already burned:"
  echo "  1. Rotate the credential AT THE PROVIDER FIRST (repo is public +"
  echo "     auto-deploys — assume compromised the moment it is pushed)."
  echo "  2. THEN rewrite history to purge it (git filter-repo / BFG)."
  echo "  3. Log the incident in SECURITY-RISKS.md's History log."
  echo "  (False positive? Use an obviously-fake placeholder instead.)"
  exit 1
fi
echo "PASS: no credential-shaped tokens found ($mode scan)."
exit 0
