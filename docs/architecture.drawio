        <mxCell id="sm1" value="POST /api/chat {messages, model, time_budget_s, web_search}" style="html=1;exitX=1;exitY=0.03;entryX=0;entryY=0.03;" edge="1" parent="1" source="s_lc" target="s_lw">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sm2" value="200 text/event-stream · x-request-id (stream opens)" style="html=1;exitX=0;exitY=0.08;entryX=1;entryY=0.08;dashed=1;" edge="1" parent="1" source="s_lw" target="s_lc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sm3" value="triage — stream:false, response_format json_object" style="html=1;exitX=1;exitY=0.13;entryX=0;entryY=0.13;" edge="1" parent="1" source="s_lw" target="s_lb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sm4" value="{action: direct | clarify | research, queries[]} + usage" style="html=1;exitX=0;exitY=0.17;entryX=1;entryY=0.17;dashed=1;" edge="1" parent="1" source="s_lb" target="s_lw">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sm5" value="status: step_start / step_done &quot;plan&quot; (details: queries)" style="html=1;exitX=0;exitY=0.22;entryX=1;entryY=0.22;dashed=1;" edge="1" parent="1" source="s_lw" target="s_lc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sm6" value="status: search_start {round, query}" style="html=1;exitX=0;exitY=0.27;entryX=1;entryY=0.27;dashed=1;" edge="1" parent="1" source="s_lw" target="s_lc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sm7" value="POST /search {query, type:auto, numResults:5, contents.highlights}" style="html=1;exitX=1;exitY=0.31;entryX=0;entryY=0.31;" edge="1" parent="1" source="s_lw" target="s_le">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sm8" value="results[] {title, url, highlights[]}" style="html=1;exitX=0;exitY=0.35;entryX=1;entryY=0.35;dashed=1;" edge="1" parent="1" source="s_le" target="s_lw">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sm9" value="status: search_done {results, duration_ms, sources[]} → registry [n]" style="html=1;exitX=0;exitY=0.39;entryX=1;entryY=0.39;dashed=1;" edge="1" parent="1" source="s_lw" target="s_lc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s_note_loop" value="× one per planned query,&lt;br&gt;deduped, capped by plan.maxSearches" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;size=14;" vertex="1" parent="1">
          <mxGeometry x="580" y="410" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="sm10" value="gap check — json_object (question + source digest + past queries)" style="html=1;exitX=1;exitY=0.47;entryX=0;entryY=0.47;" edge="1" parent="1" source="s_lw" target="s_lb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sm11" value="{complete} | {queries: follow-ups}" style="html=1;exitX=0;exitY=0.51;entryX=1;entryY=0.51;dashed=1;" edge="1" parent="1" source="s_lb" target="s_lw">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sm12" value="status: step gapN done → follow-up searches loop back (budget-gated)" style="html=1;exitX=0;exitY=0.55;entryX=1;entryY=0.55;dashed=1;" edge="1" parent="1" source="s_lw" target="s_lc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sm13" value="synthesis — stream:true (digest [n] + image parts of latest msg)" style="html=1;exitX=1;exitY=0.62;entryX=0;entryY=0.62;" edge="1" parent="1" source="s_lw" target="s_lb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sm14" value="SSE deltas (choices[0].delta.content) + usage chunks" style="html=1;exitX=0;exitY=0.66;entryX=1;entryY=0.66;dashed=1;" edge="1" parent="1" source="s_lb" target="s_lw">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sm15" value="forwarded text deltas — answer streams into the bubble (markdown-rendered live)" style="html=1;exitX=0;exitY=0.7;entryX=1;entryY=0.7;dashed=1;" edge="1" parent="1" source="s_lw" target="s_lc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sm16" value="post-validation — json_object (draft + same digest)" style="html=1;exitX=1;exitY=0.77;entryX=0;entryY=0.77;" edge="1" parent="1" source="s_lw" target="s_lb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sm17" value="{verdict: pass | revise, issues[], revised_answer}" style="html=1;exitX=0;exitY=0.81;entryX=1;entryY=0.81;dashed=1;" edge="1" parent="1" source="s_lb" target="s_lw">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sm18" value="on revise: status discard_text (UI clears draft) + revised answer as deltas" style="html=1;exitX=0;exitY=0.86;entryX=1;entryY=0.86;dashed=1;" edge="1" parent="1" source="s_lw" target="s_lc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sm19" value="status: done {model, rounds, searches, duration_ms, tokens}" style="html=1;exitX=0;exitY=0.92;entryX=1;entryY=0.92;dashed=1;" edge="1" parent="1" source="s_lw" target="s_lc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sm20" value="data: [DONE] — activity bars collapse to one summary bar" style="html=1;exitX=0;exitY=0.97;entryX=1;entryY=0.97;dashed=1;" edge="1" parent="1" source="s_lw" target="s_lc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s_note_fwd" value="Clients MUST ignore unknown status types (forward compatibility). Solid = request, dashed = response / SSE event." style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;size=14;" vertex="1" parent="1">
          <mxGeometry x="60" y="1100" width="440" height="40" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
