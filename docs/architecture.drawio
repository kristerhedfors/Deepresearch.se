<mxfile host="app.diagrams.net" agent="deepresearch-architecture">
  <diagram id="page-system" name="1 System context &amp; deployment">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="780" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="cl" value="Clients" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#666666;verticalAlign=top;fontStyle=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="80" width="190" height="280" as="geometry" />
        </mxCell>
        <mxCell id="cl_browser" value="Browser" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="150" height="40" as="geometry" />
        </mxCell>
        <mxCell id="cl_pwa" value="Installed PWA&lt;br&gt;(login page + dr_session cookie)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="180" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cl_curl" value="curl / scripts&lt;br&gt;(HTTP Basic Auth)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="260" width="150" height="50" as="geometry" />
        </mxCell>

        <mxCell id="wk" value="Cloudflare Worker — deepresearch-se (edge, no origin, no storage)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6c8ebf;verticalAlign=top;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="20" width="440" height="620" as="geometry" />
        </mxCell>
        <mxCell id="wk_index" value="src/index.js — entrypoint&lt;br&gt;request id · auth gate · routing · x-request-id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="300" y="60" width="400" height="50" as="geometry" />
        </mxCell>
        <mxCell id="wk_auth" value="src/auth.js&lt;br&gt;Basic Auth + HMAC session cookie&lt;br&gt;(fail closed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="300" y="130" width="190" height="60" as="geometry" />
        </mxCell>
        <mxCell id="wk_login" value="src/login.js&lt;br&gt;HTML login page&lt;br&gt;(PWAs cannot answer 401)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="510" y="130" width="190" height="60" as="geometry" />
        </mxCell>
        <mxCell id="wk_assets" value="env.ASSETS — static UI (public/)&lt;br&gt;run_worker_first = true&lt;br&gt;icons/manifest auth-exempt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="300" y="210" width="190" height="60" as="geometry" />
        </mxCell>
        <mxCell id="wk_models" value="/api/models&lt;br&gt;catalog filtered: text + streaming + json_mode; 5-min cache" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="510" y="210" width="190" height="60" as="geometry" />
        </mxCell>
        <mxCell id="wk_chat" value="src/chat.js — POST /api/chat&lt;br&gt;validate · resolve model · budget plan · SSE scaffold (done + [DONE] always)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="300" y="290" width="400" height="50" as="geometry" />
        </mxCell>
        <mxCell id="wk_pipe" value="src/pipeline.js — orchestrated research (no function calling)&lt;br&gt;triage → search wave → gap loop → synthesis → validation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="300" y="360" width="400" height="60" as="geometry" />
        </mxCell>
        <mxCell id="wk_budget" value="src/budget.js&lt;br&gt;per-model EWMA phase stats&lt;br&gt;plan + deadline checks (+15%)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="300" y="440" width="190" height="60" as="geometry" />
        </mxCell>
        <mxCell id="wk_valid" value="src/validation.js&lt;br&gt;message/image caps&lt;br&gt;model + vision resolution" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="510" y="440" width="190" height="60" as="geometry" />
        </mxCell>
        <mxCell id="wk_berget" value="src/berget.js&lt;br&gt;streaming + JSON-mode client&lt;br&gt;SSE consumer · model catalog" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="300" y="520" width="190" height="60" as="geometry" />
        </mxCell>
        <mxCell id="wk_exa" value="src/exa.js&lt;br&gt;Exa search client&lt;br&gt;(errors degrade to strings)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="510" y="520" width="190" height="60" as="geometry" />
        </mxCell>

        <mxCell id="ex_secrets" value="Secrets (Cloudflare bindings, never in repo)&lt;br&gt;BERGET_API_TOKEN · EXA_API_KEY&lt;br&gt;BASIC_AUTH_USER · BASIC_AUTH_PASS" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;size=14;" vertex="1" parent="1">
          <mxGeometry x="790" y="30" width="270" height="70" as="geometry" />
        </mxCell>
        <mxCell id="ex_berget" value="Berget.ai — api.berget.ai/v1&lt;br&gt;OpenAI-compatible LLM API&lt;br&gt;chat/completions (stream + json) · models&lt;br&gt;body limit ~1 MB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="790" y="150" width="270" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ex_exa" value="Exa — api.exa.ai/search&lt;br&gt;type:auto · numResults:5 · contents.highlights" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="790" y="270" width="270" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ex_logs" value="Workers Logs&lt;br&gt;structured JSON: {time, level, event, request_id, ...}&lt;br&gt;no secrets, no chat content at info+" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
