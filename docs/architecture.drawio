        <mxCell id="s_hc" value="Client UI&lt;br&gt;(public/js/app.js)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="20" width="160" height="50" as="geometry" />
