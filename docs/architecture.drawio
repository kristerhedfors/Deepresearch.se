        <mxCell id="s_he" value="Exa&lt;br&gt;/search" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="20" width="140" height="50" as="geometry" />
        </mxCell>

        <mxCell id="s_lc" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1">
