  <diagram id="page-routing" name="2 Request routing &amp; auth">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="r_start" value="Incoming request&lt;br&gt;(run_worker_first: Worker sees everything, static assets included)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="320" y="20" width="300" height="50" as="geometry" />
        </mxCell>
        <mxCell id="r_rid" value="Assign request id (UUID)&lt;br&gt;every response gets x-request-id · every log line carries it" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="320" y="100" width="300" height="50" as="geometry" />
        </mxCell>
        <mxCell id="r_d1" value="Public asset?&lt;br&gt;GET/HEAD favicon.ico,&lt;br&gt;manifest.webmanifest, /icons/*" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="360" y="180" width="220" height="110" as="geometry" />
        </mxCell>
        <mxCell id="r_pub" value="env.ASSETS.fetch — NO auth&lt;br&gt;(iOS/Chrome fetch PWA icons without credentials; behind auth they 401 silently)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="700" y="200" width="280" height="70" as="geometry" />
        </mxCell>
        <mxCell id="r_d2" value="POST /login ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="390" y="320" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="r_login" value="verifyCredentials(form) vs secrets&lt;br&gt;OK: 303 → / with Set-Cookie dr_session = exp.hmac(exp)&lt;br&gt;(30 d, Secure, HttpOnly, SameSite=Lax)&lt;br&gt;fail: 401 login page again" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="700" y="310" width="280" height="100" as="geometry" />
        </mxCell>
        <mxCell id="r_d3" value="isAuthenticated?&lt;br&gt;Basic header valid&lt;br&gt;OR dr_session HMAC valid + unexpired&lt;br&gt;(missing secrets → always NO)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="350" y="440" width="240" height="130" as="geometry" />
        </mxCell>
        <mxCell id="r_d4" value="/api/* path?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="80" y="460" width="160" height="90" as="geometry" />
        </mxCell>
        <mxCell id="r_401json" value="401 JSON&lt;br&gt;{&quot;error&quot;:&quot;Authentication required.&quot;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="30" y="620" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="r_401html" value="401 HTML login page&lt;br&gt;no WWW-Authenticate challenge&lt;br&gt;(native dialog = black screen in PWAs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="30" y="720" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="r_d5" value="Route" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="400" y="620" width="140" height="80" as="geometry" />
        </mxCell>
        <mxCell id="r_chat" value="POST /api/chat&lt;br&gt;research pipeline (SSE)&lt;br&gt;→ see page 3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="320" y="760" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="r_models" value="GET /api/models&lt;br&gt;filtered Berget catalog&lt;br&gt;(down models: up:false, greyed out)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="530" y="760" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="r_assets" value="env.ASSETS.fetch&lt;br&gt;static chat UI (public/)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="760" y="760" width="180" height="70" as="geometry" />
        </mxCell>

        <mxCell id="re1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="r_start" target="r_rid">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="r_rid" target="r_d1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re3" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="r_d1" target="r_pub">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re4" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="r_d1" target="r_d2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re5" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="r_d2" target="r_login">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re6" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="r_d2" target="r_d3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re7" value="no (auth.denied logged)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" edge="1" parent="1" source="r_d3" target="r_d4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re8" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.35;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="r_d4" target="r_401json">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re9" value="no (HTML nav)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0;exitY=0.5;entryX=0.5;entryY=0;" edge="1" parent="1" source="r_d4" target="r_401html">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re10" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="r_d3" target="r_d5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re11" value="/api/chat POST" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.25;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="r_d5" target="r_chat">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re12" value="/api/models GET" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.75;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="r_d5" target="r_models">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="re13" value="everything else" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=1;exitY=0.5;entryX=0.5;entryY=0;" edge="1" parent="1" source="r_d5" target="r_assets">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="page-pipeline" name="3 Research pipeline data flow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1150" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="p_in" value="POST /api/chat&lt;br&gt;{messages, model?, time_budget_s?, web_search?}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="330" y="20" width="300" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p_handler" value="src/chat.js — handler&lt;br&gt;validateMessages (60 msgs · 32K chars · image caps 4/8/300K/750K)&lt;br&gt;resolveModel (catalog · up · vision) — 400 on violation&lt;br&gt;clampBudget 15–600 s → planResearch(model, budget)&lt;br&gt;state: source registry · ranQueries · usage totals" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="290" y="100" width="380" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p_plan_note" value="Budget plan (src/budget.js)&lt;br&gt;EWMA (α .3) per-model phase durations, seeded priors&lt;br&gt;fixed = triage + synth (always paid)&lt;br&gt;validation reserved next (quality gate)&lt;br&gt;~60% of rest → 1–6 search angles&lt;br&gt;remainder → gap rounds (≤4)&lt;br&gt;runtime: fitsDeadline = budget +15% grace" style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;size=14;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="740" y="90" width="330" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p_dknob" value="web_search knob?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="390" y="240" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p_off" value="OFF: one streamed Berget completion&lt;br&gt;(searchOffPrompt — no triage, no Exa)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="740" y="250" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p_triage" value="Phase 1 — TRIAGE (Berget, json_object, ≤500 tok)&lt;br&gt;input: formatted conversation + latest message&lt;br&gt;out: direct | clarify(question) | research(queries[])&lt;br&gt;SSE: step_start/step_done &quot;plan&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="290" y="350" width="380" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p_dtriage" value="decision&lt;br&gt;(normalizeTriage — on junk: fallback to research with raw question, or direct)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="360" y="470" width="240" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p_direct" value="Stream direct answer&lt;br&gt;(directPrompt + conversation)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="40" y="480" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p_clarify" value="Emit ONE clarifying question&lt;br&gt;(emitChunked → same delta path)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="40" y="560" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p_search" value="Phase 2 — SEARCH WAVE&lt;br&gt;for each planned query (≤ plan.queries): dedupe (case-insensitive) · cap plan.maxSearches&lt;br&gt;→ Exa POST /search → addSources: registry deduped by URL, numbered [n] in arrival order, ≤3 highlights, cap plan.maxSources&lt;br&gt;SSE per query: search_start / search_done {results, duration_ms, sources[]}&lt;br&gt;recordPhase(search) feeds EWMA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="250" y="620" width="460" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p_dgaploop" value="Gap loop&lt;br&gt;round ≤ plan.gapIterations&lt;br&gt;AND searches &lt; cap&lt;br&gt;AND fitsDeadline(gap + 2·search + synth + validate)?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="350" y="780" width="260" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p_gapcheck" value="Phase 3 — GAP CHECK (json, ≤400 tok)&lt;br&gt;audit: question vs source digest + past queries&lt;br&gt;out: complete | follow-up queries (≤ plan.followups)&lt;br&gt;SSE: step gapN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="720" y="790" width="340" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p_dfollow" value="follow-ups?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="810" y="910" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p_followsearch" value="Run follow-up searches&lt;br&gt;→ same registry · iterations++" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="770" y="1020" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p_synth" value="Phase 4 — SYNTHESIS (Berget, stream: true)&lt;br&gt;input: question + conversation + numbered source digest (cap 14–18K chars) + image parts of latest user message&lt;br&gt;rule: answer ONLY from the numbered sources — [n] citations + &quot;Sources:&quot; list, Markdown&lt;br&gt;SSE: step &quot;synth&quot; + forwarded text deltas · recordPhase(synth)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="250" y="950" width="460" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p_dval" value="plan.validate&lt;br&gt;AND fitsDeadline(validate)?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="380" y="1090" width="200" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p_valskip" value="SSE step: &quot;Validation skipped to meet the Ns time target&quot;&lt;br&gt;(logged chat.budget_cut)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="40" y="1110" width="260" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p_validate" value="Phase 5 — POST-VALIDATION (json, ≤3000 tok)&lt;br&gt;fact-check draft vs the SAME numbered digest&lt;br&gt;out: pass | revise {issues[], revised_answer} | inconclusive" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="290" y="1220" width="380" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p_revise" value="on revise:&lt;br&gt;SSE discard_text (UI clears draft)&lt;br&gt;→ emitChunked(revised_answer)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="740" y="1225" width="250" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p_done" value="finally (always, even on error):&lt;br&gt;SSE done {model, rounds, searches, duration_ms, tokens} → data: [DONE]&lt;br&gt;log chat.complete" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="290" y="1330" width="380" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p_failsoft" value="FAIL-SOFT INVARIANT&lt;br&gt;triage / gap / validation run via phase():&lt;br&gt;error or unparseable JSON → null → degrade&lt;br&gt;(fallback query · skip round · keep draft).&lt;br&gt;Exa errors return strings, never throw.&lt;br&gt;A helper phase can never fail the request." style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;size=14;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="770" width="270" height="130" as="geometry" />
        </mxCell>

        <mxCell id="pe1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="p_in" target="p_handler">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pe2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;dashed=1;exitX=0;exitY=0.5;entryX=1;entryY=0.15;" edge="1" parent="1" source="p_plan_note" target="p_handler">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pe3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="p_handler" target="p_dknob">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pe4" value="off" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="p_dknob" target="p_off">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pe5" value="on (default)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="p_dknob" target="p_triage">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pe6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;" edge="1" parent="1" source="p_triage" target="p_dtriage">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pe7" value="direct" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0;exitY=0.3;entryX=1;entryY=0.5;" edge="1" parent="1" source="p_dtriage" target="p_direct">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pe8" value="clarify" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0;exitY=0.7;entryX=1;entryY=0.5;" edge="1" parent="1" source="p_dtriage" target="p_clarify">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pe9" value="research: queries sliced to plan.queries" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="p_dtriage" target="p_search">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pe10" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="p_search" target="p_dgaploop">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pe11" value="proceed" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="p_dgaploop" target="p_gapcheck">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pe12" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="p_gapcheck" target="p_dfollow">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pe13" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="p_dfollow" target="p_followsearch">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pe14" value="next round" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0;exitY=0.5;entryX=0.5;entryY=1;" edge="1" parent="1" source="p_followsearch" target="p_dgaploop">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pe15" value="coverage sufficient" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.2;" edge="1" parent="1" source="p_dfollow" target="p_synth">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pe16" value="budget cut / cap / rounds done" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="p_dgaploop" target="p_synth">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pe17" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="p_synth" target="p_dval">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pe18" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;" edge="1" parent="1" source="p_dval" target="p_valskip">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pe19" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="p_dval" target="p_validate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pe20" value="revise" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="p_validate" target="p_revise">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pe21" value="pass / inconclusive" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="p_validate" target="p_done">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pe22" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=1;entryX=1;entryY=0.3;" edge="1" parent="1" source="p_revise" target="p_done">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="pe23" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=1;entryX=0;entryY=0.5;dashed=1;" edge="1" parent="1" source="p_valskip" target="p_done">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="page-sse" name="4 SSE stream sequence">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1150" pageHeight="1150" math="0" shadow="0">
      <root>
        <mxCell id="0" />
